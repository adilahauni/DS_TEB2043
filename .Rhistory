# -----------------------------
# Data Cleaning Script (R)
# -----------------------------
library(dplyr)
library(readxl)
library(stringr)
# Read Excel file
df_raw <- read_excel("C:/Users/My/OneDrive - Universiti Teknologi PETRONAS/Unclean Dataset.xlsx")
# If Excel shows everything in ONE column, convert to character
raw_data <- df_raw[[1]]
# Split by pipe |
split_data <- str_split(raw_data, "\\|")
# Convert to data frame
df <- as.data.frame(do.call(rbind, split_data))
# Trim whitespace
df[] <- lapply(df, str_trim)
# Remove empty columns
df <- df[, colSums(is.na(df) | df == "") < nrow(df)]
# Set proper column names
colnames(df) <- c(
"Student_ID",
"First_Name",
"Last_Name",
"Age",
"Gender",
"Course",
"Enrollment_Date",
"Total_Payments"
)
# Remove header row
df <- df[-1, ]
# Replace "NA" string with actual NA
df[df == "NA"] <- NA
# Convert data types
df$Age <- as.numeric(df$Age)
df$Total_Payments <- as.numeric(
gsub("$", "", df$Total_Payments, fixed = TRUE)
)
df$Enrollment_Date <- as.Date(df$Enrollment_Date)
# Remove duplicates
df <- distinct(df)
# Save cleaned file
write.csv(df, "Clean_Dataset.csv", row.names = FALSE)
cat("Data cleaning completed successfully!\n")
